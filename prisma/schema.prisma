generator client {
  provider = "prisma-client-js"
}

// Aquí le decimos que usaremos PostgreSQL (el motor de Supabase)
datasource db {
  provider  = "postgresql"
}

// 1. La tabla del Negocio
model Store {
  id          String     @id @default(uuid())
  name        String     // Ej: "Burgers Carlos"
  slug        String     @unique // Ej: "burgers-carlos" (Esto es para la URL única)
  whatsapp    String     // El número donde llegarán los pedidos
  logoUrl     String?    
  createdAt   DateTime   @default(now())
  
  // Relación: Un local tiene muchas categorías
  categories  Category[] 
}

// 2. La tabla de Categorías (Para ordenar el menú)
model Category {
  id          String    @id @default(uuid())
  name        String    // Ej: "Hamburguesas", "Bebidas", "Postres"
  
  // Relación: Esta categoría pertenece a un local específico
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  // Relación: Una categoría tiene muchos productos
  products    Product[]
  createdAt   DateTime  @default(now())
}

// 3. La tabla de Productos
model Product {
  id          String    @id @default(uuid())
  name        String    // Ej: "Hamburguesa Clásica"
  description String?   // Ej: "Carne 150g, queso fundido y papitas"
  price       Float     // Ej: 5.50
  isAvailable Boolean   @default(true) // ¡La magia para apagar productos agotados!
  imageUrl    String?   
  
  // Relación: Este producto pertenece a una categoría
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}